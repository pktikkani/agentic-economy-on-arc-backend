# =============================================================================
# DROP YOUR KEYS HERE. Copy this file to `.env` and fill in values.
# =============================================================================

# ----- Gemini (Google AI Studio) -----
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ----- Circle (Developer Console) -----
# Get from: https://console.circle.com/  (API Keys section)
# Needed for faucet + wallet ops. Not strictly required for pure on-chain x402,
# but useful for checking balances via Circle APIs and for the Google track
# (function calling into Circle APIs).
CIRCLE_API_KEY=

# ----- Circle Developer-Controlled Wallet (the BUYER) -----
# These are populated automatically by scripts/bootstrap-circle-wallet.ts.
# Do NOT set manually. The bootstrap registers an entity secret, creates a
# wallet set + wallet on Arc testnet, and writes all four values here.
# Keep ./output/ (the recovery file) safe if you care about key recovery.
# No local BUYER_PRIVATE_KEY is required for the main demo flow.
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
CIRCLE_WALLET_ADDRESS=

# ----- EVM Wallets for the 5 BROKER agents -----
# Plain EVM keys (brokers sign their own ERC-8004 registrations; these wallets
# only need ~0.01 USDC of gas each). Generate with:
#   node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
BROKER_A_PRIVATE_KEY=0x
BROKER_B_PRIVATE_KEY=0x
BROKER_C_PRIVATE_KEY=0x
BROKER_D_PRIVATE_KEY=0x
BROKER_E_PRIVATE_KEY=0x

# ----- Arc Testnet Connection -----
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app
USDC_CONTRACT=0x3600000000000000000000000000000000000000
